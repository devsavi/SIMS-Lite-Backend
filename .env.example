# =============================================================================
# SIMS Lite Backend - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="SIMS Lite Backend"
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
APP_ALLOWED_HOSTS=["*"]

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=sims_user
DB_PASSWORD=sims_password
DB_NAME=sims_lite
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Constructed from the above:
# DATABASE_URL=postgresql+asyncpg://sims_user:sims_password@localhost:5432/sims_lite

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# Constructed from the above:
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# MinIO (Object Storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9010
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_DEFAULT=sims-files
MINIO_BUCKET_PUBLIC=sims-public

# -----------------------------------------------------------------------------
# JWT Authentication (prepared for Phase 1)
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-this-to-a-long-random-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Email (prepared for Phase 1)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=smtp-password
SMTP_TLS=true
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME="SIMS Lite"

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
